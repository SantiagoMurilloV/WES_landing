---
import "../styles/global.css";
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";
import ScrollProgress from "../components/ScrollProgress.astro";
import { site, services } from "../data/site";

interface Props {
  title?: string;
  description?: string;
}

const { title, description } = Astro.props;
const pageTitle = title ?? `${site.name} — ${site.tagline}`;
const pageDesc = description ?? site.description;
const canonical = "https://wesagenciadeseguros.com/";

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "InsuranceAgency",
  name: site.name,
  url: canonical,
  logo: canonical + "favicon.svg",
  description: site.description,
  slogan: site.tagline,
  foundingDate: "1975",
  telephone: site.phone,
  email: site.email,
  address: {
    "@type": "PostalAddress",
    streetAddress: site.address,
    addressLocality: "Armenia",
    addressRegion: "Quindío",
    addressCountry: "CO",
  },
  areaServed: { "@type": "Country", name: "Colombia" },
  sameAs: [site.social.instagram, site.social.facebook],
  aggregateRating: {
    "@type": "AggregateRating",
    ratingValue: "4.9",
    reviewCount: "612",
  },
  hasOfferCatalog: {
    "@type": "OfferCatalog",
    name: "Coberturas",
    itemListElement: services.map((s) => ({
      "@type": "Offer",
      itemOffered: { "@type": "Service", name: s.title, description: s.summary },
    })),
  },
};
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="canonical" href={canonical} />
    <title>{pageTitle}</title>
    <meta name="description" content={pageDesc} />
    <meta name="keywords" content="seguros Colombia, seguros Armenia, seguros familiares, seguro auto Colombia, seguro vida, seguro hogar, agencia de seguros Quindío, WES seguros, asesores de seguros, Allianz, Sura, Bolívar" />
    <meta name="author" content={site.name} />

    <!-- Open Graph -->
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDesc} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:site_name" content={site.name} />
    <meta property="og:locale" content="es_CO" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={pageDesc} />

    <meta name="theme-color" content="#0A1A2F" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,300..600;1,9..144,300..500&family=Inter:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap"
    />

    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  </head>
  <body>
    <a class="skip-link" href="#main">Saltar al contenido</a>
    <ScrollProgress />
    <Nav />
    <main id="main">
      <slot />
    </main>
    <Footer />

    <script is:inline>
      // Scroll reveal
      const io = new IntersectionObserver(
        (entries) => {
          entries.forEach((e) => {
            if (e.isIntersecting) {
              e.target.classList.add("is-visible");
              io.unobserve(e.target);
            }
          });
        },
        { threshold: 0.12, rootMargin: "0px 0px -8% 0px" }
      );
      document.querySelectorAll("[data-reveal]").forEach((el) => io.observe(el));

      // Counters
      const counterIO = new IntersectionObserver(
        (entries) => {
          entries.forEach((e) => {
            if (!e.isIntersecting) return;
            const el = e.target;
            const target = +el.dataset.count;
            const duration = 1600;
            const start = performance.now();
            const step = (now) => {
              const p = Math.min((now - start) / duration, 1);
              const eased = 1 - Math.pow(1 - p, 3);
              el.textContent = Math.floor(eased * target).toLocaleString("es-CO");
              if (p < 1) requestAnimationFrame(step);
              else el.textContent = target.toLocaleString("es-CO");
            };
            requestAnimationFrame(step);
            counterIO.unobserve(el);
          });
        },
        { threshold: 0.6 }
      );
      document.querySelectorAll("[data-count]").forEach((el) => counterIO.observe(el));

      // Sticky nav state
      const nav = document.querySelector("[data-nav]");
      if (nav) {
        const onScroll = () => {
          if (window.scrollY > 24) nav.classList.add("is-scrolled");
          else nav.classList.remove("is-scrolled");
        };
        window.addEventListener("scroll", onScroll, { passive: true });
        onScroll();
      }

      // Mobile nav toggle (any [data-nav-toggle] toggles the menu)
      const navToggles = document.querySelectorAll("[data-nav-toggle]");
      const navMenu = document.querySelector("[data-nav-menu]");
      const setMenu = (open) => {
        if (!navMenu) return;
        navMenu.classList.toggle("is-open", open);
        navToggles.forEach((t) => t.setAttribute("aria-expanded", open ? "true" : "false"));
        document.body.classList.toggle("nav-open", open);
      };
      if (navMenu && navToggles.length) {
        navToggles.forEach((t) =>
          t.addEventListener("click", () => setMenu(!navMenu.classList.contains("is-open")))
        );
        navMenu.querySelectorAll("a").forEach((a) =>
          a.addEventListener("click", () => setMenu(false))
        );
        // Cerrar con Escape
        document.addEventListener("keydown", (e) => {
          if (e.key === "Escape" && navMenu.classList.contains("is-open")) setMenu(false);
        });
      }

      // FAQ accordion
      document.querySelectorAll("[data-faq] details").forEach((d) => {
        d.addEventListener("toggle", () => {
          if (d.open) {
            d.parentElement
              ?.querySelectorAll("details")
              .forEach((other) => {
                if (other !== d) other.removeAttribute("open");
              });
          }
        });
      });

      // Splash fade
      window.addEventListener("load", () => {
        document.body.classList.add("is-loaded");
      });
    </script>

    <div class="splash" aria-hidden="true">
      <div class="splash__inner">
        <span class="splash__mark">
          <svg viewBox="0 0 97.39 111.72" fill="none" xmlns="http://www.w3.org/2000/svg">
            <polygon class="splash__poly splash__poly--1" points="30.75 101.58 48.7 111.72 97.39 84.24 97.39 63.14 30.75 101.58" fill="var(--cream-50)"/>
            <polygon class="splash__poly splash__poly--2" points="48.7 0 0 27.49 0 84.24 9 89.3 97.39 38.02 97.39 27.49 89.05 22.78 18.81 63.53 18.81 37.71 66.49 10.04 48.7 0" fill="var(--cream-50)"/>
            <circle class="splash__dot" cx="92" cy="100" r="4" fill="var(--gold-500)"/>
          </svg>
        </span>
        <span class="splash__text">
          <span class="splash__brand">WES</span>
          <span class="splash__tag">Agencia de Seguros</span>
        </span>
      </div>
    </div>

    <style is:global>
      .skip-link {
        position: absolute;
        top: -100px;
        left: 1rem;
        background: var(--ink-900);
        color: var(--cream-50);
        padding: 0.6rem 1rem;
        border-radius: var(--radius-sm);
        z-index: 999;
        transition: top 0.2s;
      }
      .skip-link:focus { top: 1rem; }
      body.nav-open { overflow: hidden; }

      .splash {
        position: fixed;
        inset: 0;
        z-index: 200;
        background: linear-gradient(165deg, var(--ink-900) 0%, var(--ink-800) 70%, var(--ink-700) 100%);
        display: grid;
        place-items: center;
        transition: opacity 0.6s var(--ease-out-expo) 0.2s, visibility 0s linear 0.8s;
        pointer-events: none;
        overflow: hidden;
      }
      .splash::before {
        content: "";
        position: absolute;
        width: 600px; height: 600px;
        border-radius: 50%;
        background: radial-gradient(circle, rgba(216,181,102,0.2), transparent 60%);
        top: 50%; left: 50%;
        transform: translate(-50%, -50%);
        filter: blur(80px);
        pointer-events: none;
      }
      body.is-loaded .splash {
        opacity: 0;
        visibility: hidden;
      }
      .splash__inner {
        position: relative;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 1.2rem;
      }
      .splash__mark {
        width: 64px;
        height: 72px;
        display: inline-grid;
        place-items: center;
        animation: splashFloat 2.4s var(--ease-out-expo) infinite alternate;
      }
      .splash__mark svg { width: 100%; height: 100%; overflow: visible; }
      .splash__poly {
        opacity: 0;
        transform-origin: center;
        animation: splashPolyIn 0.7s var(--ease-out-expo) forwards;
      }
      .splash__poly--1 {
        animation-delay: 0.05s;
        transform: translateY(-12px);
      }
      .splash__poly--2 {
        animation-delay: 0.18s;
        transform: translateY(12px);
      }
      .splash__dot {
        opacity: 0;
        animation: splashFade 0.5s var(--ease-out-expo) 0.6s forwards;
      }
      .splash__text {
        display: inline-flex;
        flex-direction: column;
        align-items: center;
        gap: 0.3rem;
        opacity: 0;
        transform: translateY(8px);
        animation: splashFadeUp 0.6s var(--ease-out-expo) 0.4s forwards;
      }
      .splash__brand {
        font-family: var(--font-serif);
        font-size: 1.6rem;
        font-weight: 500;
        letter-spacing: 0.32em;
        color: var(--cream-50);
      }
      .splash__tag {
        font-family: var(--font-sans);
        font-size: 0.62rem;
        font-weight: 500;
        letter-spacing: 0.4em;
        text-transform: uppercase;
        color: var(--gold-400);
      }
      @keyframes splashPolyIn {
        to { opacity: 1; transform: translateY(0); }
      }
      @keyframes splashFade {
        to { opacity: 1; }
      }
      @keyframes splashFadeUp {
        to { opacity: 1; transform: translateY(0); }
      }
      @keyframes splashFloat {
        from { transform: translateY(0); }
        to { transform: translateY(-4px); }
      }
    </style>
  </body>
</html>
