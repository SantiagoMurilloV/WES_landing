---
import Logo from "./Logo.astro";
import { navLinks, site } from "../data/site";
---

<div class="nav__backdrop" data-nav-toggle aria-hidden="true"></div>

<header class="nav" data-nav>
  <div class="nav__inner container">
    <Logo />
    <nav class="nav__desktop" aria-label="Principal">
      <ul>
        {navLinks.map((l) => (
          <li><a href={l.href}>{l.label}</a></li>
        ))}
      </ul>
    </nav>
    <button class="nav__toggle" data-nav-toggle aria-label="Abrir menú" aria-expanded="false">
      <span></span><span></span><span></span>
    </button>
  </div>
</header>

<!-- Mobile menu — fuera del nav para no depender de su containing block -->
<nav class="nav__menu" data-nav-menu aria-label="Menú móvil">
  <div class="nav__menu-bg" aria-hidden="true">
    <div class="nav__menu-glow"></div>
    <div class="nav__menu-grid"></div>
  </div>

  <div class="nav__menu-head">
    <span class="nav__menu-eyebrow">Menú</span>
  </div>

  <ul>
    {navLinks.map((l, i) => (
      <li style={`--i: ${i}`}>
        <a href={l.href}>
          <span class="nav__num">·{String(i + 1).padStart(2, "0")}</span>
          <span class="nav__label">{l.label}</span>
          <span class="nav__arrow" aria-hidden="true">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none">
              <path d="M5 12h14M13 6l6 6-6 6" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/>
            </svg>
          </span>
        </a>
      </li>
    ))}
  </ul>

  <div class="nav__menu-foot">
    <a href={site.phoneLink}>{site.phone}</a>
    <a href={site.emailLink}>{site.email}</a>
  </div>
</nav>

<style>
  /* NAV BAR */
  .nav {
    position: fixed;
    inset: 0 0 auto 0;
    z-index: 50;
    padding: 1.1rem 0;
    transition: padding 0.4s var(--ease-out-expo), background 0.4s, border-color 0.4s;
  }
  .nav.is-scrolled {
    padding: 0.55rem 0;
    background: rgba(251, 248, 242, 0.78);
    backdrop-filter: saturate(140%) blur(18px);
    -webkit-backdrop-filter: saturate(140%) blur(18px);
    border-bottom: 1px solid rgba(6, 18, 31, 0.06);
  }
  .nav__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 2rem;
  }

  /* Desktop nav links */
  .nav__desktop {
    display: flex;
    align-items: center;
    gap: 2rem;
  }
  .nav__desktop ul {
    display: flex;
    gap: 1.8rem;
  }
  .nav__desktop a {
    position: relative;
    font-size: 0.9rem;
    font-weight: 500;
    color: var(--ink-800);
    transition: color 0.3s;
  }
  .nav__desktop ul a::after {
    content: "";
    position: absolute;
    left: 0;
    bottom: -6px;
    width: 0;
    height: 1px;
    background: var(--gold-500);
    transition: width 0.4s var(--ease-out-expo);
  }
  .nav__desktop ul a:hover { color: var(--gold-600); }
  .nav__desktop ul a:hover::after { width: 100%; }
  .nav__cta { padding: 0.7rem 1.2rem; font-size: 0.85rem; }

  /* Backdrop overlay (mobile) */
  .nav__backdrop {
    position: fixed;
    inset: 0;
    background: rgba(6, 18, 31, 0.55);
    backdrop-filter: blur(6px);
    -webkit-backdrop-filter: blur(6px);
    opacity: 0;
    visibility: hidden;
    pointer-events: none;
    z-index: 49;
    transition: opacity 0.35s var(--ease-out-expo), visibility 0s linear 0.35s;
  }
  body.nav-open .nav__backdrop {
    opacity: 1;
    visibility: visible;
    pointer-events: auto;
    transition: opacity 0.35s var(--ease-out-expo), visibility 0s linear 0s;
  }

  /* Toggle (hamburger) */
  .nav__toggle {
    display: none;
    position: relative;
    flex-direction: column;
    gap: 5px;
    width: 40px;
    height: 40px;
    align-items: center;
    justify-content: center;
    border-radius: 50%;
    border: 1px solid rgba(6,18,31,0.12);
    background: var(--white);
    z-index: 60;
    transition: background 0.3s, border-color 0.3s;
  }
  .nav__toggle:hover { border-color: var(--gold-500); }
  .nav__toggle span {
    width: 16px;
    height: 1.5px;
    background: var(--ink-900);
    transition: transform 0.4s var(--ease-out-expo), opacity 0.3s;
    transform-origin: center;
  }
  body.nav-open .nav__toggle span:nth-child(1) {
    transform: translateY(6.5px) rotate(45deg);
  }
  body.nav-open .nav__toggle span:nth-child(2) { opacity: 0; }
  body.nav-open .nav__toggle span:nth-child(3) {
    transform: translateY(-6.5px) rotate(-45deg);
  }
  body.nav-open .nav__toggle {
    background: var(--cream-50);
  }

  /* Mobile menu — oculto en desktop */
  .nav__menu { display: none; }

  @media (max-width: 880px) {
    .nav {
      background: rgba(251, 248, 242, 0.92);
      backdrop-filter: saturate(140%) blur(18px);
      -webkit-backdrop-filter: saturate(140%) blur(18px);
      border-bottom: 1px solid rgba(39,43,73,0.06);
      padding: 0.7rem 0;
    }
    .nav__desktop { display: none; }
    .nav__toggle { display: inline-flex; }

    /* MOBILE MENU — dropdown compacto */
    .nav__menu {
      position: fixed;
      top: 4.4rem;
      right: 1rem;
      width: min(340px, calc(100vw - 2rem));
      max-height: calc(100vh - 5.5rem);
      background: linear-gradient(165deg, var(--ink-900) 0%, var(--ink-800) 70%, var(--ink-700) 100%);
      color: var(--cream-50);
      border-radius: 22px;
      padding: 1.4rem 1.5rem 1.6rem;
      transform: translateY(-12px) scale(0.96);
      transform-origin: top right;
      opacity: 0;
      visibility: hidden;
      pointer-events: none;
      transition: transform 0.4s var(--ease-out-expo), opacity 0.3s var(--ease-out-expo), visibility 0s linear 0.3s;
      overflow-y: auto;
      z-index: 55;
      isolation: isolate;
      box-shadow:
        0 20px 60px -15px rgba(6,18,31,0.55),
        0 0 0 1px rgba(255,255,255,0.06);
      display: flex;
      flex-direction: column;
    }
    .nav__menu.is-open {
      transform: translateY(0) scale(1);
      opacity: 1;
      visibility: visible;
      pointer-events: auto;
      transition: transform 0.4s var(--ease-out-expo), opacity 0.3s var(--ease-out-expo), visibility 0s linear 0s;
    }

    /* Decorative bg */
    .nav__menu-bg {
      position: absolute;
      inset: 0;
      z-index: -1;
      pointer-events: none;
    }
    .nav__menu-glow {
      position: absolute;
      width: 480px; height: 480px;
      border-radius: 50%;
      background: radial-gradient(circle, rgba(216,181,102,0.22), transparent 60%);
      top: -20%;
      right: -30%;
      filter: blur(80px);
    }
    .nav__menu-grid {
      position: absolute; inset: 0;
      background-image:
        linear-gradient(rgba(255,255,255,0.04) 1px, transparent 1px),
        linear-gradient(90deg, rgba(255,255,255,0.04) 1px, transparent 1px);
      background-size: 60px 60px;
      mask-image: radial-gradient(ellipse 80% 60% at 70% 30%, #000 30%, transparent 100%);
    }

    /* Menu head */
    .nav__menu-head {
      display: flex;
      justify-content: flex-start;
      align-items: center;
      padding: 0.2rem 0.4rem 0.9rem;
      margin-bottom: 0.4rem;
      border-bottom: 1px solid rgba(255,255,255,0.08);
    }
    .nav__menu-eyebrow {
      font-size: 0.62rem;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      color: var(--gold-400);
      font-weight: 500;
    }

    /* List */
    .nav__menu ul {
      list-style: none;
      padding: 0;
      margin: 0;
      display: flex;
      flex-direction: column;
      gap: 0;
      width: 100%;
      flex: 1;
    }
    .nav__menu ul li {
      opacity: 0;
      transform: translateX(20px);
      transition: opacity 0.5s var(--ease-out-expo), transform 0.5s var(--ease-out-expo);
      transition-delay: calc(var(--i) * 0.06s + 0.15s);
    }
    .nav__menu.is-open ul li {
      opacity: 1;
      transform: translateX(0);
    }
    .nav__menu ul a {
      display: flex;
      align-items: center;
      gap: 0.8rem;
      padding: 0.85rem 0.6rem;
      border-radius: 12px;
      color: var(--cream-50);
      font-family: var(--font-serif);
      font-size: 1.15rem;
      font-weight: 400;
      letter-spacing: -0.01em;
      text-decoration: none;
      transition: all 0.3s var(--ease-out-expo);
    }
    .nav__menu ul a:hover, .nav__menu ul a:focus-visible {
      background: rgba(255,255,255,0.06);
      color: var(--gold-400);
    }
    .nav__num {
      display: inline-block;
      font-family: var(--font-mono);
      font-size: 0.62rem;
      color: var(--gold-400);
      letter-spacing: 0.1em;
      min-width: 22px;
      opacity: 0.8;
    }
    .nav__label { flex: 1; }
    .nav__arrow {
      display: inline-grid;
      place-items: center;
      width: 26px;
      height: 26px;
      border-radius: 50%;
      background: rgba(255,255,255,0.05);
      color: var(--cream-50);
      transition: all 0.3s;
      opacity: 0.7;
    }
    .nav__arrow svg { width: 12px; height: 12px; }
    .nav__menu ul a:hover .nav__arrow {
      background: var(--gold-500);
      color: var(--ink-900);
      transform: translateX(2px);
      opacity: 1;
    }

    /* Foot */
    .nav__menu-foot {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 0.3rem;
      margin-top: 0.6rem;
      padding: 0.9rem 0.4rem 0.2rem;
      border-top: 1px solid rgba(255,255,255,0.08);
      font-size: 0.74rem;
      color: rgba(255,255,255,0.55);
      opacity: 0;
      transition: opacity 0.4s 0.4s;
    }
    .nav__menu.is-open .nav__menu-foot { opacity: 1; }
    .nav__menu-foot a { color: rgba(255,255,255,0.85); text-decoration: none; }
    .nav__menu-foot a:hover { color: var(--gold-400); }
  }
  @media (max-width: 540px) {
    .nav__inner > .logo .logo__tag { display: none; }
  }
</style>
