---
import ServiceIcon from "./ServiceIcon.astro";
import { services, site } from "../data/site";
---

<section class="services section" id="coberturas">
  <div class="services__bg" aria-hidden="true">
    <svg viewBox="0 0 1200 600" preserveAspectRatio="none" class="services__pattern">
      <defs>
        <pattern id="dots" x="0" y="0" width="22" height="22" patternUnits="userSpaceOnUse">
          <circle cx="2" cy="2" r="1" fill="rgba(6,18,31,0.1)"/>
        </pattern>
      </defs>
      <rect width="1200" height="600" fill="url(#dots)"/>
    </svg>
  </div>

  <div class="container">
    <header class="section-head" data-reveal>
      <span class="eyebrow">Nuestras coberturas</span>
      <h2>
        Pólizas <span class="accent">a tu medida</span>,<br/>
        no de catálogo.
      </h2>
      <p>
        Cada cliente, cada familia y cada empresa es distinta. Diseñamos pólizas combinando coberturas
        de las mejores aseguradoras del país para que pagues solo por lo que realmente necesitas.
      </p>
    </header>

    <div class="services__grid">
      {services.map((s, i) => (
        <article class="service" data-reveal data-reveal-delay={(i % 3) + 1} data-tilt-soft>
          <div class="service__shine" aria-hidden="true"></div>
          <div class="service__icon"><ServiceIcon name={s.icon} /></div>
          <h3 class="service__title">{s.title}</h3>
          <p class="service__summary">{s.summary}</p>
          <ul class="service__bullets">
            {s.bullets.map((b) => (
              <li>
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                  <path d="M5 12l4 4 10-10" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
                {b}
              </li>
            ))}
          </ul>
          <a class="service__link" href={site.whatsapp} target="_blank" rel="noopener">
            Cotizar ahora
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" aria-hidden="true">
              <path d="M5 12h14M13 6l6 6-6 6" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </a>
          <span class="service__num">0{services.indexOf(s) + 1}</span>
        </article>
      ))}
    </div>
  </div>
</section>

<script is:inline>
  // Tilt suave + spotlight para servicios
  (function () {
    if (window.matchMedia("(pointer: coarse)").matches) return;
    const cards = document.querySelectorAll("[data-tilt-soft]");
    cards.forEach((card) => {
      card.addEventListener("mousemove", (e) => {
        const r = card.getBoundingClientRect();
        const x = (e.clientX - r.left) / r.width;
        const y = (e.clientY - r.top) / r.height;
        card.style.setProperty("--mx", x * 100 + "%");
        card.style.setProperty("--my", y * 100 + "%");
        card.style.transform = `perspective(1000px) rotateX(${(0.5 - y) * 4}deg) rotateY(${(x - 0.5) * 5}deg) translateY(-4px)`;
      });
      card.addEventListener("mouseleave", () => {
        card.style.transform = "";
      });
    });
  })();
</script>

<style>
  .services {
    background: var(--cream-50);
    position: relative;
    isolation: isolate;
    overflow: hidden;
  }
  .services__bg {
    position: absolute;
    inset: 0;
    z-index: -1;
    opacity: 0.4;
    mask-image: radial-gradient(ellipse 60% 80% at 50% 100%, #000 0%, transparent 70%);
  }
  .services__pattern { width: 100%; height: 100%; }

  .services__grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1.25rem;
    perspective: 1500px;
  }

  .service {
    --mx: 50%;
    --my: 50%;
    position: relative;
    padding: 2.2rem 2rem 2rem;
    background: var(--white);
    border: 1px solid rgba(39,43,73,0.06);
    border-radius: var(--radius-lg);
    transition: all 0.5s var(--ease-out-expo);
    overflow: hidden;
    isolation: isolate;
    will-change: transform;
    transform-style: preserve-3d;
  }
  .service::after {
    content: "";
    position: absolute;
    top: 0;
    left: 2rem;
    right: 2rem;
    height: 2px;
    background: linear-gradient(90deg, var(--gold-500), transparent);
    opacity: 0;
    transform: scaleX(0);
    transform-origin: left;
    transition: opacity 0.4s, transform 0.6s var(--ease-out-expo);
  }
  .service:hover::after { opacity: 1; transform: scaleX(1); }
  .service::before {
    content: "";
    position: absolute;
    inset: 0;
    background: radial-gradient(60% 60% at var(--mx) var(--my), rgba(216,181,102,0.12), transparent 70%);
    opacity: 0;
    transition: opacity 0.4s;
    z-index: -1;
    pointer-events: none;
  }
  .service__shine {
    position: absolute;
    inset: 0;
    border-radius: inherit;
    background: linear-gradient(135deg, transparent 40%, rgba(216,181,102,0.18), transparent 60%);
    opacity: 0;
    transition: opacity 0.6s;
    pointer-events: none;
    mix-blend-mode: overlay;
  }
  .service:hover {
    border-color: rgba(201, 162, 74, 0.4);
    box-shadow: var(--shadow-md);
  }
  .service:hover::before { opacity: 1; }
  .service:hover .service__shine { opacity: 1; }
  .service:hover .service__icon { background: var(--ink-900); border-color: var(--ink-900); }
  .service:hover .service__icon svg { color: var(--gold-400); transform: scale(1.05) rotate(-3deg); }

  .service__icon {
    width: 56px;
    height: 56px;
    border-radius: var(--radius-md);
    background: var(--cream-100);
    border: 1px solid rgba(6,18,31,0.06);
    display: grid;
    place-items: center;
    margin-bottom: 1.4rem;
    transition: all 0.5s var(--ease-out-expo);
  }

  .service__title {
    font-size: var(--fs-xl);
    margin-bottom: 0.5rem;
  }
  .service__summary {
    color: var(--muted-700);
    margin-bottom: 1.4rem;
    font-size: 0.95rem;
  }
  .service__bullets {
    display: grid;
    gap: 0.5rem;
    margin-bottom: 1.6rem;
    padding-bottom: 1.4rem;
    border-bottom: 1px solid rgba(39,43,73,0.06);
  }
  .service__bullets li {
    display: flex;
    gap: 0.6rem;
    align-items: center;
    font-size: 0.88rem;
    color: var(--ink-700);
  }
  .service__bullets svg { color: var(--gold-600); flex-shrink: 0; }

  .service__link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.88rem;
    font-weight: 500;
    color: var(--ink-900);
    transition: gap 0.3s var(--ease-out-expo), color 0.3s;
  }
  .service__link:hover { color: var(--gold-600); gap: 0.8rem; }

  .service__num {
    position: absolute;
    top: 1.4rem;
    right: 1.6rem;
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--muted-300);
    letter-spacing: 0.1em;
  }

  @media (max-width: 920px) {
    .services__grid { grid-template-columns: repeat(2, minmax(0, 1fr)); }
  }
  @media (max-width: 600px) {
    .services__grid { grid-template-columns: 1fr; }
  }
</style>
