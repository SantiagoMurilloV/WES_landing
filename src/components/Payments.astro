---
import { partners } from "../data/site";
const helpUrl = "https://wa.me/573177674325?text=Hola%20WES%2C%20necesito%20ayuda%20con%20el%20pago%20de%20mi%20p%C3%B3liza.";
---

<section class="payments section" id="pagos">
  <div class="payments__bg" aria-hidden="true">
    <div class="payments__orb"></div>
  </div>

  <div class="container">
    <header class="payments__head" data-reveal>
      <div class="payments__pretitle">
        <span class="payments__line"></span>
        <span class="payments__pre">Medios de pago</span>
      </div>
      <h2>
        Paga tu póliza en línea,<br/>
        <em class="serif-italic">directo y seguro.</em>
      </h2>
      <p>
        Selecciona tu aseguradora y te llevamos al portal oficial de pagos.
        Todas las transacciones se realizan a través de <strong>PSE</strong> u otros canales
        autorizados directamente con la compañía emisora.
      </p>

      <div class="payments__safety">
        <span class="payments__safety-icon" aria-hidden="true">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
            <rect x="5" y="11" width="14" height="9" rx="2"/>
            <path d="M8 11V8a4 4 0 0 1 8 0v3"/>
          </svg>
        </span>
        <div>
          <strong>Pago 100% seguro</strong>
          <span>Vigilado por la Superintendencia Financiera</span>
        </div>
      </div>
    </header>

    <div class="payments__grid">
      {partners.map((p, i) => (
        <a
          class="paycard"
          href={p.paymentUrl}
          target="_blank"
          rel="noopener noreferrer"
          aria-label={`Pagar mi póliza con ${p.name}`}
          data-reveal
          data-reveal-delay={(i % 4) + 1}
        >
          <span class="paycard__num">·{String(i + 1).padStart(2, "0")}</span>

          <div class="paycard__logo">
            <img
              src={p.logo}
              alt={p.name}
              loading="eager"
              decoding="async"
              style={`transform: scale(${p.scale ?? 1});`}
            />
          </div>

          <div class="paycard__foot">
            <div class="paycard__info">
              <span class="paycard__label">Pagar mi seguro</span>
              <span class="paycard__name">{p.name}</span>
            </div>
            <span class="paycard__arrow" aria-hidden="true">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none">
                <path d="M5 12h14M13 6l6 6-6 6" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </span>
          </div>
        </a>
      ))}

      <a
        class="paycard paycard--cta"
        href={helpUrl}
        target="_blank"
        rel="noopener noreferrer"
        aria-label="¿No ves tu aseguradora? Habla con un asesor"
        data-reveal
        data-reveal-delay="4"
      >
        <span class="paycard__num">·{String(partners.length + 1).padStart(2, "0")}</span>

        <div class="paycard__logo paycard__logo--cta">
          <span class="paycard__cta-icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
              <path d="M21 11.5a8.4 8.4 0 0 1-9 8.5 8.5 8.5 0 0 1-3.8-.9L3 20l1.5-4.2A8.5 8.5 0 1 1 21 11.5z"/>
            </svg>
          </span>
          <span class="paycard__cta-title">¿No ves tu aseguradora?</span>
        </div>

        <div class="paycard__foot">
          <div class="paycard__info">
            <span class="paycard__label paycard__label--cta">Asistencia 1 a 1</span>
            <span class="paycard__name">Habla con asesor</span>
          </div>
          <span class="paycard__arrow paycard__arrow--cta" aria-hidden="true">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none">
              <path d="M5 12h14M13 6l6 6-6 6" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </span>
        </div>
      </a>
    </div>
  </div>
</section>

<style>
  .payments {
    position: relative;
    background: linear-gradient(180deg, var(--cream-50) 0%, #FBF8F2 100%);
    overflow: hidden;
    isolation: isolate;
  }

  .payments__bg { position: absolute; inset: 0; z-index: -1; pointer-events: none; }
  .payments__orb {
    position: absolute;
    width: 600px; height: 600px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(216,181,102,0.18), transparent 60%);
    top: -10%;
    right: -10%;
    filter: blur(100px);
    opacity: 0.5;
  }

  /* HEAD — apilado y centrado */
  .payments__head {
    text-align: center;
    max-width: 720px;
    margin: 0 auto 4rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.4rem;
  }
  .payments__pretitle {
    display: inline-flex;
    align-items: center;
    gap: 0.7rem;
  }
  .payments__line { width: 36px; height: 1px; background: var(--gold-500); }
  .payments__pre {
    font-size: 0.74rem;
    font-weight: 500;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--gold-600);
  }
  .payments__head h2 {
    font-size: clamp(2rem, 1.4rem + 2.4vw, 3rem);
    line-height: 1.05;
    letter-spacing: -0.02em;
    max-width: 18ch;
    margin: 0 auto;
  }
  .payments__head h2 em {
    background: linear-gradient(110deg, var(--gold-600), var(--gold-400) 60%, var(--gold-600));
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
  }
  .payments__head p {
    font-size: var(--fs-base);
    color: var(--muted-700);
    line-height: 1.6;
    max-width: 56ch;
    margin: 0 auto;
  }
  .payments__head p strong { color: var(--ink-800); font-weight: 500; }

  .payments__safety {
    display: inline-flex;
    align-items: center;
    gap: 0.9rem;
    padding: 0.55rem 1.2rem 0.55rem 0.55rem;
    border-radius: var(--radius-pill);
    background: var(--white);
    border: 1px solid rgba(39,43,73,0.08);
    box-shadow: var(--shadow-soft);
    margin-top: 0.4rem;
  }
  .payments__safety-icon {
    flex-shrink: 0;
    display: inline-grid;
    place-items: center;
    width: 36px;
    height: 36px;
    border-radius: 50%;
    background: linear-gradient(135deg, rgba(216,181,102,0.18), rgba(216,181,102,0.08));
    color: var(--gold-600);
  }
  .payments__safety-icon svg { width: 18px; height: 18px; }
  .payments__safety > div {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    text-align: left;
  }
  .payments__safety strong {
    font-size: 0.9rem;
    font-weight: 500;
    color: var(--ink-900);
    line-height: 1.2;
  }
  .payments__safety > div > span {
    font-size: 0.74rem;
    color: var(--muted-500);
    margin-top: 0.1rem;
  }

  /* GRID — 4 columnas fijas, 8 cards (7 aseguradoras + 1 CTA) */
  .payments__grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 1.2rem;
  }

  /* PAYCARD */
  .paycard {
    position: relative;
    display: flex;
    flex-direction: column;
    background: var(--white);
    border: 1px solid rgba(39,43,73,0.08);
    border-radius: var(--radius-lg);
    padding: 1.6rem 1.4rem 1.3rem;
    text-decoration: none;
    color: inherit;
    transition: all 0.5s var(--ease-out-expo);
    overflow: hidden;
    isolation: isolate;
    min-height: 220px;
  }
  .paycard::before {
    content: "";
    position: absolute;
    inset: 0;
    background: radial-gradient(80% 60% at 100% 0%, rgba(216,181,102,0.08), transparent 70%);
    opacity: 0;
    transition: opacity 0.4s;
    z-index: -1;
  }
  .paycard:hover {
    transform: translateY(-6px);
    border-color: rgba(216,181,102,0.4);
    box-shadow: var(--shadow-md);
  }
  .paycard:hover::before { opacity: 1; }
  .paycard:hover .paycard__arrow {
    background: var(--ink-900);
    color: var(--gold-400);
    transform: translateX(3px) rotate(-3deg);
  }

  .paycard__num {
    position: absolute;
    top: 1rem;
    right: 1.2rem;
    font-family: var(--font-mono);
    font-size: 0.7rem;
    color: var(--muted-300);
    letter-spacing: 0.1em;
  }

  .paycard__logo {
    flex: 1;
    display: grid;
    place-items: center;
    width: 100%;
    margin-bottom: 1.1rem;
    padding: 1rem 0.5rem;
    min-height: 88px;
  }
  .paycard__logo img {
    max-width: 80%;
    max-height: 60px;
    width: auto;
    height: auto;
    object-fit: contain;
    transition: transform 0.5s var(--ease-out-expo);
  }

  .paycard__foot {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 0.8rem;
    padding-top: 1rem;
    border-top: 1px solid rgba(39,43,73,0.08);
  }
  .paycard__info {
    display: flex;
    flex-direction: column;
    min-width: 0;
    flex: 1;
  }
  .paycard__label {
    display: block;
    font-size: 0.68rem;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: var(--gold-600);
    font-weight: 500;
    margin-bottom: 0.25rem;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .paycard__name {
    display: block;
    font-family: var(--font-serif);
    font-size: 1rem;
    font-weight: 500;
    color: var(--ink-900);
    line-height: 1.2;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .paycard__arrow {
    flex-shrink: 0;
    width: 36px;
    height: 36px;
    border-radius: 50%;
    display: grid;
    place-items: center;
    background: var(--gold-500);
    color: var(--ink-900);
    transition: all 0.4s var(--ease-out-expo);
  }

  /* CTA card (8va) */
  .paycard--cta {
    background: linear-gradient(135deg, var(--ink-800), var(--ink-700));
    border-color: var(--ink-700);
    color: var(--cream-50);
    overflow: hidden;
  }
  .paycard--cta::after {
    content: "";
    position: absolute;
    width: 240px; height: 240px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(216,181,102,0.22), transparent 60%);
    top: -50%;
    right: -20%;
    filter: blur(40px);
    pointer-events: none;
  }
  .paycard--cta .paycard__num {
    color: rgba(255,255,255,0.35);
  }
  .paycard__logo--cta {
    flex-direction: column;
    gap: 0.7rem;
    text-align: center;
    align-content: center;
  }
  .paycard__cta-icon {
    width: 48px;
    height: 48px;
    border-radius: 50%;
    background: rgba(216,181,102,0.16);
    color: var(--gold-400);
    display: grid;
    place-items: center;
  }
  .paycard__cta-icon svg { width: 22px; height: 22px; }
  .paycard__cta-title {
    font-family: var(--font-serif);
    font-size: 1.05rem;
    line-height: 1.2;
    color: var(--cream-50);
    max-width: 18ch;
  }
  .paycard--cta .paycard__foot {
    border-top-color: rgba(255,255,255,0.12);
  }
  .paycard__label--cta { color: var(--gold-400); }
  .paycard--cta .paycard__name { color: var(--cream-50); }
  .paycard__arrow--cta {
    background: var(--gold-500);
    color: var(--ink-900);
  }
  .paycard--cta:hover .paycard__arrow--cta {
    background: var(--cream-50);
    color: var(--ink-900);
  }

  @media (max-width: 1100px) {
    .payments__grid { grid-template-columns: repeat(3, minmax(0, 1fr)); }
  }
  @media (max-width: 820px) {
    .payments__grid { grid-template-columns: repeat(2, minmax(0, 1fr)); }
  }
  @media (max-width: 540px) {
    .payments__grid { grid-template-columns: 1fr; }
    .paycard { min-height: 200px; }
  }
</style>
