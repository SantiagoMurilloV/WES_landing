---
interface Props { name: string; }
const { name } = Astro.props;
---

<svg viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
  {name === "auto" && (
    <g stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round">
      <path d="M8 30v-6l3-9c.6-1.8 2.3-3 4.2-3h17.6c1.9 0 3.6 1.2 4.2 3l3 9v6"/>
      <path d="M6 30h36v6a2 2 0 0 1-2 2h-3a2 2 0 0 1-2-2v-2H13v2a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2v-6Z"/>
      <circle cx="14" cy="33" r="2.2"/>
      <circle cx="34" cy="33" r="2.2"/>
      <path d="M11 23h26"/>
    </g>
  )}
  {name === "vida" && (
    <g stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round">
      <path d="M24 40C12 32 7 25 7 18.5 7 13 11 9 16 9c3.4 0 6.4 2 8 5 1.6-3 4.6-5 8-5 5 0 9 4 9 9.5 0 6.5-5 13.5-17 21.5Z"/>
    </g>
  )}
  {name === "salud" && (
    <g stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round">
      <path d="M6 24h8l3-7 6 14 3-7h16"/>
      <circle cx="32" cy="14" r="2.5" fill="currentColor"/>
    </g>
  )}
  {name === "hogar" && (
    <g stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round">
      <path d="M8 22 24 9l16 13"/>
      <path d="M11 20v17a2 2 0 0 0 2 2h22a2 2 0 0 0 2-2V20"/>
      <path d="M19 39v-9h10v9"/>
      <circle cx="24" cy="25" r="1.4" fill="currentColor"/>
    </g>
  )}
  {name === "empresa" && (
    <g stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round">
      <path d="M8 41V12l14-5 14 5v29"/>
      <path d="M6 41h36"/>
      <path d="M14 18h4M14 24h4M14 30h4M22 18h4M22 24h4M22 30h4M30 18h4M30 24h4M30 30h4"/>
      <path d="M19 41v-6h10v6"/>
    </g>
  )}
  {name === "rc" && (
    <g stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round">
      <path d="M24 7l14 5v9c0 9-6 16-14 19-8-3-14-10-14-19v-9l14-5Z"/>
      <path d="M19 23l4 4 8-9"/>
    </g>
  )}
</svg>

<style>
  svg {
    width: 28px;
    height: 28px;
    color: var(--gold-500);
    transition: transform 0.5s var(--ease-out-expo);
  }
</style>
