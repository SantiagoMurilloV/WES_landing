---
import { site } from "../data/site";
---

<section class="contact section" id="contacto">
  <div class="contact__bg" aria-hidden="true">
    <div class="contact__glow"></div>
    <div class="contact__grid"></div>
  </div>

  <div class="container contact__inner">
    <div class="contact__copy" data-reveal>
      <span class="eyebrow">Hablemos</span>
      <h2>
        Tu tranquilidad<br/>
        empieza con una <span class="accent serif-italic">conversación.</span>
      </h2>
      <p>
        Cuéntanos qué quieres proteger y agendamos una asesoría sin costo en menos de 24 horas.
        Te respondemos en el canal que prefieras.
      </p>

      <div class="contact__channels">
        <a class="channel" href={site.whatsapp} target="_blank" rel="noopener">
          <span class="channel__icon">
            <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M20.5 3.5A11.7 11.7 0 0 0 12.1 0C5.5 0 .2 5.4.2 12c0 2.1.6 4.2 1.6 6L0 24l6.2-1.6a12 12 0 0 0 5.9 1.5h.1c6.5 0 11.9-5.4 11.9-12 0-3.2-1.3-6.2-3.6-8.4ZM12.2 21.9c-1.8 0-3.6-.5-5.2-1.4l-.4-.2-3.7 1 1-3.6-.2-.4a9.7 9.7 0 0 1-1.5-5.3c0-5.4 4.4-9.8 9.9-9.8 2.6 0 5.1 1 7 2.9a9.8 9.8 0 0 1 2.9 7c0 5.4-4.4 9.8-9.8 9.8Zm5.4-7.4c-.3-.1-1.7-.9-2-1-.3-.1-.5-.1-.7.2-.2.3-.8 1-1 1.2-.2.2-.4.2-.6.1-.3-.1-1.3-.5-2.4-1.5-.9-.8-1.5-1.8-1.7-2.1-.2-.3 0-.5.1-.6.1-.1.3-.4.4-.5.1-.2.2-.3.3-.5 0-.2 0-.3 0-.5l-.7-1.7c-.2-.4-.4-.4-.6-.4h-.5c-.2 0-.4.1-.7.3-.2.3-.9.9-.9 2.1 0 1.3.9 2.5 1.1 2.7.1.2 1.9 2.9 4.6 4 .6.3 1.1.5 1.5.6.6.2 1.2.2 1.7.1.5-.1 1.6-.7 1.9-1.3.2-.6.2-1.1.1-1.3-.1-.1-.3-.2-.5-.3Z"/></svg>
          </span>
          <div>
            <span class="channel__label">WhatsApp directo</span>
            <strong>{site.phone}</strong>
          </div>
          <svg class="channel__arrow" width="14" height="14" viewBox="0 0 24 24" fill="none" aria-hidden="true">
            <path d="M5 12h14M13 6l6 6-6 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
        <a class="channel" href={site.emailLink}>
          <span class="channel__icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" aria-hidden="true">
              <rect x="3" y="5" width="18" height="14" rx="2"/><path d="m3 7 9 6 9-6"/>
            </svg>
          </span>
          <div>
            <span class="channel__label">Correo</span>
            <strong>{site.email}</strong>
          </div>
          <svg class="channel__arrow" width="14" height="14" viewBox="0 0 24 24" fill="none" aria-hidden="true">
            <path d="M5 12h14M13 6l6 6-6 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
        <div class="channel channel--info">
          <span class="channel__icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" aria-hidden="true">
              <path d="M12 22s7-7.5 7-13a7 7 0 0 0-14 0c0 5.5 7 13 7 13Z"/><circle cx="12" cy="9" r="2.5"/>
            </svg>
          </span>
          <div>
            <span class="channel__label">Oficina</span>
            <strong>{site.address}</strong>
            <small>{site.city} · {site.hours}</small>
          </div>
        </div>
      </div>
    </div>

    <form class="contact__form" data-reveal data-reveal-delay="2" onsubmit="event.preventDefault(); const f=this; const name=f.name.value; const msg=encodeURIComponent('Hola WES, soy ' + name + '. ' + (f.message.value || 'Quiero asesoría sobre seguros.')); window.open('https://wa.me/573177674325?text=' + msg, '_blank');">
      <header>
        <span class="contact__form-tag">Asesoría gratuita</span>
        <h3>Cuéntanos sobre ti</h3>
        <p>Respondemos en menos de 24 horas hábiles.</p>
      </header>

      <label class="field">
        <span>Nombre completo</span>
        <input name="name" type="text" required placeholder="Ej. Carolina Restrepo"/>
      </label>
      <div class="field-row">
        <label class="field">
          <span>Teléfono</span>
          <input name="phone" type="tel" required placeholder="+57 300 000 0000"/>
        </label>
        <label class="field">
          <span>Tipo de seguro</span>
          <select name="type" required>
            <option value="">Selecciona…</option>
            <option>Auto</option>
            <option>Vida</option>
            <option>Salud</option>
            <option>Hogar</option>
            <option>Empresarial</option>
            <option>Responsabilidad civil</option>
            <option>No estoy seguro</option>
          </select>
        </label>
      </div>
      <label class="field">
        <span>Cuéntanos brevemente</span>
        <textarea name="message" rows="4" placeholder="¿Qué quieres asegurar y qué te preocupa cubrir?"></textarea>
      </label>

      <button type="submit" class="btn btn-gold contact__submit">
        Enviar y abrir WhatsApp
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" aria-hidden="true">
          <path d="M5 12h14M13 6l6 6-6 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </button>

      <p class="contact__legal">
        Al enviar aceptas nuestra política de tratamiento de datos. No compartimos tu información.
      </p>
    </form>
  </div>
</section>

<style>
  .contact {
    background: var(--ink-900);
    color: var(--cream-50);
    position: relative;
    overflow: hidden;
    isolation: isolate;
  }
  .contact__bg { position: absolute; inset: 0; z-index: -1; }
  .contact__grid {
    position: absolute; inset: 0;
    background-image:
      linear-gradient(rgba(255,255,255,0.03) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255,255,255,0.03) 1px, transparent 1px);
    background-size: 80px 80px;
    mask-image: radial-gradient(ellipse 80% 70% at 80% 30%, #000 30%, transparent 100%);
  }
  .contact__glow {
    position: absolute;
    width: 700px; height: 700px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(216,181,102,0.22), transparent 60%);
    bottom: -40%;
    left: -10%;
    filter: blur(80px);
  }

  .contact__inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: start;
  }

  .contact__copy h2 { color: var(--cream-50); line-height: 1.05; }
  .contact__copy .accent {
    background: linear-gradient(110deg, var(--gold-400), var(--gold-300));
    -webkit-background-clip: text; background-clip: text; color: transparent;
  }
  .contact__copy .eyebrow { color: var(--gold-400); }
  .contact__copy .eyebrow::before { background: var(--gold-400); }
  .contact__copy > p { color: rgba(255,255,255,0.7); margin-top: 1.2rem; max-width: 50ch; }

  .contact__channels {
    margin-top: 2.5rem;
    display: grid;
    gap: 0.8rem;
  }
  .channel {
    display: grid;
    grid-template-columns: auto minmax(0, 1fr) auto;
    align-items: center;
    gap: 1.1rem;
    padding: 1.2rem 1.4rem;
    background: rgba(255,255,255,0.03);
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: var(--radius-md);
    color: inherit;
    transition: all 0.4s var(--ease-out-expo);
    min-width: 0;
  }
  .channel:hover {
    background: rgba(216,181,102,0.08);
    border-color: rgba(216,181,102,0.3);
    transform: translateX(4px);
  }
  .channel > div { min-width: 0; }
  .channel__icon {
    width: 42px; height: 42px;
    display: grid; place-items: center;
    background: rgba(216,181,102,0.12);
    color: var(--gold-400);
    border-radius: 50%;
    flex-shrink: 0;
  }
  .channel__icon svg { width: 20px; height: 20px; }
  .channel__label {
    display: block;
    font-size: 0.7rem;
    color: rgba(255,255,255,0.55);
    letter-spacing: 0.16em;
    text-transform: uppercase;
    margin-bottom: 0.25rem;
  }
  .channel strong {
    display: block;
    color: var(--cream-50);
    font-weight: 500;
    font-size: 1rem;
    word-break: break-word;
    overflow-wrap: anywhere;
    line-height: 1.3;
  }
  .channel small {
    display: block;
    font-size: 0.78rem;
    color: rgba(255,255,255,0.5);
    margin-top: 0.25rem;
    word-break: break-word;
    overflow-wrap: anywhere;
    line-height: 1.4;
  }
  .channel__arrow { color: var(--gold-400); flex-shrink: 0; }
  .channel--info { cursor: default; }
  .channel--info:hover { transform: none; background: rgba(255,255,255,0.03); border-color: rgba(255,255,255,0.08); }

  /* Formulario */
  .contact__form {
    background: rgba(255,255,255,0.04);
    border: 1px solid rgba(255,255,255,0.1);
    border-radius: var(--radius-lg);
    padding: 2.4rem;
    backdrop-filter: blur(8px);
    display: grid;
    gap: 1.1rem;
    min-width: 0;
  }
  .contact__form header { margin-bottom: 0.4rem; }
  .contact__form-tag {
    display: inline-block;
    font-size: 0.72rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--gold-400);
    margin-bottom: 0.8rem;
  }
  .contact__form h3 {
    font-size: clamp(1.4rem, 1.2rem + 1vw, 1.7rem);
    color: var(--cream-50);
    margin-bottom: 0.3rem;
    line-height: 1.2;
  }
  .contact__form header p { color: rgba(255,255,255,0.6); font-size: 0.9rem; }

  .field { display: grid; gap: 0.4rem; min-width: 0; }
  .field-row { display: grid; grid-template-columns: minmax(0, 1fr) minmax(0, 1fr); gap: 1rem; }
  .field span {
    font-size: 0.78rem;
    color: rgba(255,255,255,0.6);
    letter-spacing: 0.06em;
  }
  .field input, .field select, .field textarea {
    width: 100%;
    max-width: 100%;
    background: rgba(0,0,0,0.25);
    border: 1px solid rgba(255,255,255,0.12);
    border-radius: var(--radius-sm);
    padding: 0.85rem 1rem;
    color: var(--cream-50);
    font-family: var(--font-sans);
    font-size: 0.95rem;
    transition: border-color 0.3s, background 0.3s;
    box-sizing: border-box;
  }
  .field input:focus, .field select:focus, .field textarea:focus {
    outline: none;
    border-color: var(--gold-500);
    background: rgba(0,0,0,0.35);
  }
  .field textarea { resize: vertical; min-height: 100px; }
  .field option { color: var(--ink-900); }

  .contact__submit { width: 100%; padding: 1rem 1.4rem; }

  .contact__legal {
    font-size: 0.75rem;
    color: rgba(255,255,255,0.45);
    text-align: center;
    margin-top: 0.4rem;
  }

  @media (max-width: 920px) {
    .contact__inner { grid-template-columns: 1fr; gap: 3rem; }
    .field-row { grid-template-columns: minmax(0, 1fr); }
  }
  @media (max-width: 540px) {
    .contact__copy h2 { font-size: clamp(1.8rem, 1.4rem + 2vw, 2.4rem); }
    .contact__channels { margin-top: 1.8rem; }
    .channel {
      padding: 1rem 1.1rem;
      gap: 0.85rem;
    }
    .channel__icon {
      width: 38px; height: 38px;
    }
    .channel__icon svg { width: 18px; height: 18px; }
    .channel strong { font-size: 0.9rem; }
    .channel small { font-size: 0.72rem; }
    .channel__label { font-size: 0.62rem; }

    .contact__form {
      padding: 1.6rem 1.3rem;
      border-radius: 16px;
    }
    .contact__form h3 { font-size: 1.3rem; }
    .field input, .field select, .field textarea {
      padding: 0.75rem 0.9rem;
      font-size: 0.92rem;
    }
    .contact__submit {
      padding: 0.9rem 1.2rem;
      font-size: 0.9rem;
    }
  }
</style>
