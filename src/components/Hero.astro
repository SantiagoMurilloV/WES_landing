---
import { site } from "../data/site";
const rotators = ["tu familia", "tu auto", "tu hogar", "tu salud", "tu negocio"];
---

<section class="hero" id="top">
  <div class="hero__bg" aria-hidden="true">
    <div class="hero__grid" data-parallax data-parallax-speed="0.04"></div>
    <div class="hero__glow hero__glow--gold" data-parallax data-parallax-speed="-0.05"></div>
    <div class="hero__glow hero__glow--ink" data-parallax data-parallax-speed="0.06"></div>
  </div>

  <div class="hero__inner container">
    <div class="hero__content">
      <div class="hero__badge" data-reveal>
        <span class="badge"><span class="dot"></span>+{site.yearsOfTrust} años protegiendo familias en Colombia</span>
      </div>

      <h1 class="hero__title" data-reveal data-reveal-delay="1">
        Asegura
        <span class="rotator" aria-live="polite">
          <span class="rotator__inner" data-rotator>
            {rotators.map((w) => (<span class="rotator__word">{w}</span>))}
          </span>
          <span class="rotator__cursor" aria-hidden="true"></span>
        </span><br/>
        con quien <em>te conoce</em><br/>
        por <span class="hero__title-accent">tu nombre.</span>
      </h1>

      <p class="hero__lead" data-reveal data-reveal-delay="2">
        Más de cinco décadas asesorando personas y empresas con la mejor relación
        cobertura-precio del mercado. Pólizas a tu medida, con cercanía y total respaldo.
      </p>

      <div class="hero__cta" data-reveal data-reveal-delay="3">
        <a href={site.whatsapp} target="_blank" rel="noopener" class="btn btn-gold" data-magnetic>
          Quiero mi asesoría gratis
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" aria-hidden="true">
            <path d="M5 12h14M13 6l6 6-6 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
        <a href="#cotizar" class="btn-link">
          Cotizar en 60 segundos
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" aria-hidden="true">
            <path d="M12 5v14M5 12l7 7 7-7" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
      </div>

      <div class="hero__trust" data-reveal data-reveal-delay="4">
        <span class="hero__trust-icon" aria-hidden="true">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
            <path d="M12 2 4 6v6c0 5 3.5 9 8 10 4.5-1 8-5 8-10V6l-8-4Z"/>
            <path d="m9 12 2 2 4-4"/>
          </svg>
        </span>
        <div class="hero__trust-text">
          <strong>Vigilados por la Superfinanciera</strong>
          <span>Pólizas emitidas por aseguradoras autorizadas</span>
        </div>
      </div>
    </div>

    <div class="hero__visual" data-reveal data-reveal-delay="3">
      <div class="hero__photo" data-tilt>
        <img
          src="/media/familia-scaled.jpg"
          alt="Familia abrazada en un momento de tranquilidad"
          loading="eager"
          decoding="async"
        />

        <div class="hero__chip hero__chip--policy">
          <span class="hero__chip-dot"></span>
          <div>
            <p class="hero__chip-name">Plan recomendado</p>
            <p class="hero__chip-plan">Integral 360°</p>
          </div>
        </div>

        <div class="hero__chip hero__chip--time">
          <p class="hero__chip-label">Tiempo de respuesta</p>
          <p class="hero__chip-big">2.4<span> h</span></p>
        </div>
      </div>
    </div>
  </div>
</section>

<script is:inline>
  // Rotador
  (function () {
    const rotator = document.querySelector("[data-rotator]");
    if (!rotator) return;
    const words = Array.from(rotator.children);
    if (words.length === 0) return;
    let idx = 0;
    const setActive = (n) => {
      words.forEach((w, i) => w.classList.toggle("is-active", i === n));
      // +6px buffer for italic kerning and cursor
      const widest = words[n].getBoundingClientRect().width;
      rotator.style.width = Math.ceil(widest) + 8 + "px";
    };
    setActive(0);
    setInterval(() => { idx = (idx + 1) % words.length; setActive(idx); }, 2400);
    window.addEventListener("resize", () => setActive(idx));
  })();

  // Parallax
  (function () {
    const els = document.querySelectorAll("[data-parallax]");
    if (els.length === 0) return;
    let ticking = false;
    const update = () => {
      const y = window.scrollY;
      els.forEach((el) => {
        const speed = parseFloat(el.dataset.parallaxSpeed || "0.05");
        el.style.transform = `translate3d(0, ${y * speed}px, 0)`;
      });
      ticking = false;
    };
    window.addEventListener("scroll", () => {
      if (!ticking) { requestAnimationFrame(update); ticking = true; }
    }, { passive: true });
  })();

  // Tilt
  (function () {
    if (window.matchMedia("(pointer: coarse)").matches) return;
    document.querySelectorAll("[data-tilt]").forEach((card) => {
      card.addEventListener("mousemove", (e) => {
        const r = card.getBoundingClientRect();
        const x = (e.clientX - r.left) / r.width - 0.5;
        const y = (e.clientY - r.top) / r.height - 0.5;
        card.style.transform = `perspective(1100px) rotateX(${-y * 3}deg) rotateY(${x * 4}deg)`;
      });
      card.addEventListener("mouseleave", () => { card.style.transform = ""; });
    });
  })();

  // Magnetic
  (function () {
    if (window.matchMedia("(pointer: coarse)").matches) return;
    document.querySelectorAll("[data-magnetic]").forEach((el) => {
      el.addEventListener("mousemove", (e) => {
        const r = el.getBoundingClientRect();
        const x = e.clientX - r.left - r.width / 2;
        const y = e.clientY - r.top - r.height / 2;
        el.style.transform = `translate(${x * 0.15}px, ${y * 0.18}px)`;
      });
      el.addEventListener("mouseleave", () => { el.style.transform = ""; });
    });
  })();
</script>

<style>
  .hero {
    position: relative;
    padding: 9rem 0 6rem;
    overflow: hidden;
    isolation: isolate;
    background: var(--cream-50);
  }

  .hero__bg { position: absolute; inset: 0; z-index: -1; }
  .hero__grid {
    position: absolute;
    inset: -10%;
    background-image:
      linear-gradient(rgba(39,43,73,0.045) 1px, transparent 1px),
      linear-gradient(90deg, rgba(39,43,73,0.045) 1px, transparent 1px);
    background-size: 80px 80px;
    background-position: center;
    mask-image: radial-gradient(ellipse 80% 70% at 50% 40%, #000 40%, transparent 100%);
  }
  .hero__glow {
    position: absolute;
    border-radius: 50%;
    filter: blur(80px);
    opacity: 0.5;
    will-change: transform;
  }
  .hero__glow--gold {
    width: 540px; height: 540px;
    background: radial-gradient(circle, rgba(216,181,102,0.45), transparent 60%);
    top: -10%; right: -8%;
  }
  .hero__glow--ink {
    width: 600px; height: 600px;
    background: radial-gradient(circle, rgba(39,43,73,0.32), transparent 60%);
    bottom: -20%; left: -10%;
  }

  .hero__inner {
    position: relative;
    display: grid;
    grid-template-columns: 1.05fr 1fr;
    gap: 4rem;
    align-items: center;
  }
  .hero__content { display: grid; gap: 1.8rem; }
  .hero__badge { justify-self: start; }

  .hero__title {
    font-size: clamp(2rem, 1.2rem + 4vw, 4.2rem);
    line-height: 1.15;
    letter-spacing: -0.025em;
    max-width: 14ch;
  }
  .hero__title em { font-style: italic; font-weight: 350; color: var(--ink-700); }
  .hero__title-accent {
    background: linear-gradient(110deg, var(--gold-600) 10%, var(--gold-400) 60%, var(--gold-600));
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
    font-style: italic;
    font-weight: 400;
  }

  .rotator {
    position: relative;
    display: inline-flex;
    vertical-align: baseline;
    align-items: center;
    overflow: hidden;
    height: 1.15em;
    padding: 0.05em 0;
    transition: width 0.5s var(--ease-out-expo);
    color: var(--gold-600);
    font-style: italic;
    font-weight: 400;
  }
  .rotator__inner { position: relative; display: inline-block; white-space: nowrap; padding-right: 0.08em; }
  .rotator__word {
    position: absolute;
    inset: 0;
    opacity: 0;
    transform: translateY(105%);
    transition: opacity 0.6s var(--ease-out-expo), transform 0.6s var(--ease-out-expo);
    background: linear-gradient(110deg, var(--gold-600), var(--gold-400) 60%, var(--gold-600));
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
  }
  .rotator__word.is-active { opacity: 1; transform: translateY(0); position: relative; }
  .rotator__cursor {
    width: 2px;
    height: 0.7em;
    background: var(--gold-500);
    margin-left: 0.18em;
    flex-shrink: 0;
    animation: blink 1.1s steps(2) infinite;
  }
  @keyframes blink { 50% { opacity: 0; } }

  .hero__lead {
    max-width: 52ch;
    font-size: var(--fs-md);
    color: var(--muted-700);
    line-height: 1.6;
  }

  .hero__cta {
    display: flex;
    align-items: center;
    gap: 1.6rem;
    flex-wrap: wrap;
  }
  [data-magnetic] { transition: transform 0.4s var(--ease-out-expo), background 0.4s, color 0.4s; }

  /* Trust */
  .hero__trust {
    display: flex;
    align-items: center;
    gap: 0.9rem;
    width: fit-content;
    max-width: 100%;
    padding: 0.7rem 1rem;
    border-radius: var(--radius-pill);
    background: rgba(255,255,255,0.5);
    border: 1px solid rgba(39,43,73,0.06);
    backdrop-filter: blur(8px);
  }
  .hero__trust-icon {
    flex-shrink: 0;
    display: inline-grid;
    place-items: center;
    width: 38px;
    height: 38px;
    border-radius: 50%;
    background: linear-gradient(135deg, rgba(216,181,102,0.18), rgba(216,181,102,0.08));
    color: var(--gold-600);
  }
  .hero__trust-icon svg { width: 20px; height: 20px; }

  .hero__trust-text strong {
    display: block;
    font-size: 0.92rem;
    font-weight: 500;
    color: var(--ink-900);
    line-height: 1.3;
  }
  .hero__trust-text span {
    font-size: 0.78rem;
    color: var(--muted-500);
  }

  /* Visual photo */
  .hero__visual {
    position: relative;
    perspective: 1400px;
  }
  .hero__photo {
    position: relative;
    aspect-ratio: 4 / 5;
    border-radius: var(--radius-xl);
    transform-style: preserve-3d;
    transition: transform 0.6s var(--ease-out-expo);
    will-change: transform;
  }
  .hero__photo img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 30%;
    border-radius: var(--radius-xl);
    box-shadow: var(--shadow-lg);
  }

  /* Floating chips — más simples, no apretados */
  .hero__chip {
    position: absolute;
    background: var(--white);
    border-radius: var(--radius-md);
    padding: 0.85rem 1.1rem;
    box-shadow: var(--shadow-md);
    border: 1px solid rgba(39,43,73,0.06);
    transform: translateZ(60px);
    backdrop-filter: blur(20px);
    animation: floaty 6s var(--ease-out-soft) infinite;
    display: flex;
    align-items: center;
    gap: 0.7rem;
  }
  @keyframes floaty {
    0%, 100% { transform: translateZ(60px) translateY(0); }
    50% { transform: translateZ(60px) translateY(-6px); }
  }

  .hero__chip--policy {
    bottom: 2rem;
    left: -1.5rem;
    animation-delay: -1s;
    background: linear-gradient(135deg, var(--ink-800), var(--ink-700));
    color: var(--cream-50);
    border-color: var(--ink-700);
  }
  .hero__chip-dot {
    width: 9px; height: 9px;
    background: #4ade80;
    border-radius: 50%;
    box-shadow: 0 0 0 3px rgba(74,222,128,0.25);
    flex-shrink: 0;
  }
  .hero__chip-name {
    font-size: 0.74rem;
    color: rgba(255,255,255,0.6);
    text-transform: uppercase;
    letter-spacing: 0.12em;
  }
  .hero__chip-plan {
    font-family: var(--font-serif);
    font-size: 1.05rem;
    color: var(--gold-400);
    line-height: 1.1;
    margin-top: 0.1rem;
  }

  .hero__chip--time {
    top: 2rem;
    right: -1.5rem;
    animation-delay: -3s;
    flex-direction: column;
    align-items: flex-start;
    gap: 0.2rem;
    padding: 1rem 1.2rem;
  }
  .hero__chip-label {
    font-size: 0.66rem;
    color: var(--muted-500);
    text-transform: uppercase;
    letter-spacing: 0.12em;
  }
  .hero__chip-big {
    font-family: var(--font-serif);
    font-size: 1.8rem;
    line-height: 1;
    color: var(--ink-900);
  }
  .hero__chip-big span { font-size: 0.85rem; color: var(--gold-600); }

  @media (max-width: 980px) {
    .hero__inner { grid-template-columns: 1fr; gap: 3rem; }
    .hero__visual { max-width: 460px; margin: 0 auto; width: 100%; }
    .hero__chip--policy { left: -1rem; }
    .hero__chip--time { right: -0.5rem; }
  }
  @media (max-width: 640px) {
    .hero { padding: 7rem 0 4rem; }
    .hero__chip {
      padding: 0.7rem 0.95rem;
      animation: none;
      transform: none !important;
    }
    .hero__chip--policy {
      left: 1rem;
      right: 1rem;
      bottom: 1rem;
      width: auto;
    }
    .hero__chip--time {
      top: 1rem;
      right: 1rem;
      left: auto;
      bottom: auto;
    }
    .hero__chip-plan { font-size: 0.95rem; }
    .hero__chip-big { font-size: 1.3rem; }
    .hero__chip-label { font-size: 0.6rem; }
    .hero__title {
      font-size: clamp(1.95rem, 1.2rem + 5.5vw, 2.6rem);
      max-width: 100%;
      letter-spacing: -0.025em;
    }
    .rotator { max-width: 100%; }
    .hero__lead { font-size: 0.98rem; }
  }
</style>
