---
import Logo from "./Logo.astro";
import { site, navLinks } from "../data/site";
const year = new Date().getFullYear();
---

<footer class="footer">
  <div class="container">
    <!-- Newsletter -->
    <div class="footer__newsletter">
      <div class="footer__newsletter-text">
        <span class="eyebrow" style="color: var(--gold-400);">Tips & noticias</span>
        <h3 class="footer__newsletter-title">
          Recibe nuestros <em class="serif-italic">consejos de protección</em> cada mes.
        </h3>
        <p>Sin spam, sin venta dura. Solo información valiosa.</p>
      </div>
      <form class="footer__newsletter-form" onsubmit="event.preventDefault(); const e = this.email.value; alert('Gracias por suscribirte. Te confirmaremos al correo: ' + e); this.reset();">
        <label class="visually-hidden" for="newsletter-email">Tu correo</label>
        <input id="newsletter-email" name="email" type="email" required placeholder="tu@correo.com" />
        <button type="submit" class="footer__newsletter-btn" aria-label="Suscribirme">
          <span>Suscribirme</span>
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" aria-hidden="true">
            <path d="M5 12h14M13 6l6 6-6 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </button>
      </form>
    </div>

    <hr class="footer__divider"/>

    <!-- Brand + columnas -->
    <div class="footer__top">
      <div class="footer__brand">
        <Logo variant="light" />
        <p>{site.tagline}. Cinco décadas asesorando a familias y empresas con cercanía y total respaldo.</p>
        <div class="footer__certs">
          <span class="footer__cert">
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" aria-hidden="true">
              <path d="M12 2 4 6v6c0 5 3.5 9 8 10 4.5-1 8-5 8-10V6l-8-4Z" stroke="currentColor" stroke-width="1.5"/>
              <path d="m9 12 2 2 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            Vigilados Superfinanciera
          </span>
        </div>
      </div>

      <div class="footer__col">
        <h5>Navegación</h5>
        <ul>
          {navLinks.map((l) => <li><a href={l.href}>{l.label}</a></li>)}
        </ul>
      </div>

      <div class="footer__col">
        <h5>Contacto</h5>
        <ul class="footer__contact">
          <li><a href={site.phoneLink}>{site.phone}</a></li>
          <li><a class="footer__email" href={site.emailLink}>{site.email}</a></li>
          <li>{site.address}</li>
          <li>{site.city}</li>
          <li>{site.hours}</li>
        </ul>
        <div class="footer__social">
          <a href={site.social.instagram} aria-label="Instagram" target="_blank" rel="noopener">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
              <rect x="3" y="3" width="18" height="18" rx="5"/>
              <circle cx="12" cy="12" r="4"/>
              <circle cx="17.5" cy="6.5" r="0.6" fill="currentColor"/>
            </svg>
          </a>
          <a href={site.social.facebook} aria-label="Facebook" target="_blank" rel="noopener">
            <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M13 22v-8h2.7l.4-3.1H13V8.9c0-.9.3-1.5 1.6-1.5h1.7v-2.8c-.3 0-1.3-.1-2.4-.1-2.4 0-4 1.4-4 4.1V11H7v3.1h2.9V22H13Z"/>
            </svg>
          </a>
          <a href={site.social.whatsapp} aria-label="WhatsApp" target="_blank" rel="noopener">
            <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M20.5 3.5A11.7 11.7 0 0 0 12.1 0C5.5 0 .2 5.4.2 12c0 2.1.6 4.2 1.6 6L0 24l6.2-1.6a12 12 0 0 0 5.9 1.5h.1c6.5 0 11.9-5.4 11.9-12 0-3.2-1.3-6.2-3.6-8.4Z"/></svg>
          </a>
        </div>
      </div>
    </div>

    <!-- Bottom -->
    <div class="footer__bottom">
      <p>© {year} {site.name}. Todos los derechos reservados.</p>
      <div class="footer__legal">
        <a href="#">Privacidad</a>
        <span aria-hidden="true">·</span>
        <a href="#">Términos</a>
        <span aria-hidden="true">·</span>
        <a href="#">Tratamiento de datos</a>
      </div>
    </div>
  </div>

  <div class="footer__watermark" aria-hidden="true">WES</div>
</footer>

<style>
  .footer {
    position: relative;
    background: var(--ink-900);
    color: var(--cream-50);
    padding: 5rem 0 1.5rem;
    overflow: hidden;
  }

  /* Newsletter */
  .footer__newsletter {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 3rem;
    align-items: end;
    padding-bottom: 3rem;
    margin-bottom: 1rem;
  }
  .footer__newsletter-title {
    font-size: clamp(1.5rem, 1.1rem + 1.5vw, 2.2rem);
    line-height: 1.15;
    color: var(--cream-50);
    margin: 0.6rem 0 0.7rem;
    max-width: 18ch;
    letter-spacing: -0.01em;
  }
  .footer__newsletter-title em { color: var(--gold-300); }
  .footer__newsletter-text p {
    color: rgba(255,255,255,0.6);
    font-size: 0.9rem;
    max-width: 38ch;
  }
  .footer__newsletter-form {
    display: flex;
    gap: 0.4rem;
    background: rgba(255,255,255,0.04);
    border: 1px solid rgba(255,255,255,0.1);
    border-radius: var(--radius-pill);
    padding: 0.35rem 0.4rem 0.35rem 1.2rem;
    transition: border-color 0.3s, background 0.3s;
    min-width: 0;
  }
  .footer__newsletter-form:focus-within {
    border-color: var(--gold-500);
    background: rgba(255,255,255,0.06);
  }
  .footer__newsletter-form input {
    flex: 1;
    min-width: 0;
    background: transparent;
    border: 0;
    outline: 0;
    color: var(--cream-50);
    font-size: 0.92rem;
    padding: 0.55rem 0;
  }
  .footer__newsletter-form input::placeholder { color: rgba(255,255,255,0.4); }
  .footer__newsletter-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.4rem;
    padding: 0.65rem 1.1rem;
    background: var(--gold-500);
    color: var(--ink-900);
    border: 0;
    border-radius: var(--radius-pill);
    font-family: var(--font-sans);
    font-size: 0.85rem;
    font-weight: 500;
    cursor: pointer;
    transition: background 0.3s, transform 0.3s var(--ease-out-expo);
    flex-shrink: 0;
    white-space: nowrap;
    line-height: 1;
  }
  .footer__newsletter-btn span { display: inline-block; }
  .footer__newsletter-btn svg { flex-shrink: 0; }
  .footer__newsletter-btn:hover {
    background: var(--gold-400);
    transform: translateY(-1px);
  }

  .footer__divider {
    border: 0;
    border-top: 1px solid rgba(255,255,255,0.08);
    margin: 0;
  }

  /* Top: brand + columnas */
  .footer__top {
    display: grid;
    grid-template-columns: 1.5fr 1fr 1.3fr;
    gap: 3rem;
    padding: 3rem 0;
    border-bottom: 1px solid rgba(255,255,255,0.08);
  }
  .footer__brand p {
    margin-top: 1.2rem;
    color: rgba(255,255,255,0.6);
    font-size: 0.9rem;
    max-width: 36ch;
    line-height: 1.55;
  }

  .footer__certs {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-top: 1.2rem;
  }
  .footer__cert {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.35rem 0.7rem;
    border-radius: var(--radius-pill);
    border: 1px solid rgba(216,181,102,0.3);
    color: var(--gold-300);
    font-size: 0.7rem;
    font-weight: 500;
    letter-spacing: 0.04em;
  }

  .footer__social {
    display: flex;
    gap: 0.5rem;
    margin-top: 1.2rem;
  }
  .footer__social a {
    width: 36px; height: 36px;
    border-radius: 50%;
    border: 1px solid rgba(255,255,255,0.15);
    display: grid;
    place-items: center;
    color: var(--cream-50);
    transition: all 0.3s var(--ease-out-expo);
  }
  .footer__social a:hover {
    background: var(--gold-500);
    border-color: var(--gold-500);
    color: var(--ink-900);
    transform: translateY(-2px);
  }
  .footer__social svg { width: 14px; height: 14px; }

  .footer__col { min-width: 0; }
  .footer__col h5 {
    font-family: var(--font-sans);
    font-size: 0.7rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--gold-400);
    margin-bottom: 1rem;
    font-weight: 500;
  }
  .footer__col ul { display: grid; gap: 0.55rem; list-style: none; padding: 0; margin: 0; }
  .footer__col a, .footer__col li {
    font-size: 0.88rem;
    color: rgba(255,255,255,0.65);
    transition: color 0.3s;
    line-height: 1.4;
  }
  .footer__col a { text-decoration: none; }
  .footer__col a:hover { color: var(--gold-400); }
  .footer__email {
    word-break: break-word;
    overflow-wrap: anywhere;
  }

  /* Bottom legal */
  .footer__bottom {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding-top: 1.5rem;
    font-size: 0.78rem;
    color: rgba(255,255,255,0.45);
    flex-wrap: wrap;
    gap: 1rem;
  }
  .footer__bottom p { color: inherit; }
  .footer__legal {
    display: flex;
    gap: 0.6rem;
    flex-wrap: wrap;
    align-items: center;
  }
  .footer__legal a { color: rgba(255,255,255,0.6); text-decoration: none; transition: color 0.3s; }
  .footer__legal a:hover { color: var(--gold-400); }
  .footer__legal span { color: rgba(255,255,255,0.25); }

  .footer__watermark {
    position: absolute;
    bottom: -3rem;
    left: 50%;
    transform: translateX(-50%);
    font-family: var(--font-serif);
    font-size: clamp(8rem, 22vw, 24rem);
    letter-spacing: 0.15em;
    color: rgba(255,255,255,0.025);
    line-height: 0.85;
    pointer-events: none;
    user-select: none;
  }

  .visually-hidden {
    position: absolute;
    width: 1px; height: 1px;
    padding: 0; margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  /* Responsive */
  @media (max-width: 920px) {
    .footer__newsletter { grid-template-columns: 1fr; gap: 1.6rem; }
    .footer__top { grid-template-columns: 1fr 1fr; gap: 2.5rem; }
    .footer__brand { grid-column: 1 / -1; }
  }

  @media (max-width: 560px) {
    .footer { padding: 3rem 0 1.4rem; }

    /* === NEWSLETTER ULTRA COMPACTO === */
    .footer__newsletter {
      gap: 1rem;
      padding-bottom: 2rem;
      margin-bottom: 0;
    }
    .footer__newsletter-title {
      font-size: 1.3rem;
      max-width: 100%;
      margin: 0.4rem 0 0.5rem;
    }
    .footer__newsletter-text p { font-size: 0.82rem; }

    .footer__newsletter-form {
      padding: 0.35rem 0.35rem 0.35rem 1rem;
      border-radius: var(--radius-pill);
      flex-direction: row;
      gap: 0.4rem;
      align-items: center;
    }
    .footer__newsletter-form input {
      padding: 0.5rem 0;
      font-size: 0.85rem;
      flex: 1;
      min-width: 0;
    }
    .footer__newsletter-btn {
      width: auto;
      padding: 0.55rem 0.9rem;
      font-size: 0.78rem;
    }
    .footer__newsletter-btn span { display: none; }
    .footer__newsletter-btn::before {
      content: "→";
      font-size: 1rem;
      line-height: 1;
    }
    .footer__newsletter-btn svg { display: none; }

    /* === LOGO BRAND OCULTO EN MOBILE (ya está en navbar) === */
    .footer__top { display: block; padding: 1.6rem 0; }
    .footer__brand { display: none; }

    /* === COL: LINKS INLINE COMO CHIPS === */
    .footer__col + .footer__col { margin-top: 1.6rem; }
    .footer__col h5 {
      font-size: 0.62rem;
      letter-spacing: 0.18em;
      margin-bottom: 0.7rem;
      color: var(--gold-400);
      text-align: center;
    }

    /* Navegación: chips horizontales centrados */
    .footer__col:nth-of-type(2) ul,
    .footer__top > .footer__col:first-of-type ul {
      display: flex;
      flex-wrap: wrap;
      justify-content: center;
      gap: 0.4rem 0.8rem;
    }
    .footer__col:nth-of-type(2) ul a,
    .footer__top > .footer__col:first-of-type ul a {
      font-size: 0.85rem;
      padding: 0;
    }

    /* Contacto: centrado vertical compacto */
    .footer__col:last-of-type ul {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 0.4rem;
      text-align: center;
    }
    .footer__col:last-of-type a, .footer__col:last-of-type li {
      font-size: 0.82rem;
    }

    /* Social: centrado, más pequeño */
    .footer__social {
      margin-top: 1.2rem;
      justify-content: center;
      gap: 0.5rem;
    }
    .footer__social a { width: 32px; height: 32px; }
    .footer__social svg { width: 13px; height: 13px; }

    /* Pill vigilados (la dejamos en el footer pero centrada) */
    .footer__brand { display: block; text-align: center; }
    .footer__brand :global(a.logo) { display: none !important; }
    .footer__brand > p { display: none !important; }
    .footer__brand .footer__certs {
      justify-content: center;
      margin-top: 0;
      margin-bottom: 1.2rem;
    }
    .footer__cert { font-size: 0.66rem; padding: 0.3rem 0.7rem; }

    /* === BOTTOM: copyright + legal centrados === */
    .footer__bottom {
      flex-direction: column;
      align-items: center;
      text-align: center;
      gap: 0.5rem;
      padding-top: 1.2rem;
      font-size: 0.7rem;
      border-top: 1px solid rgba(255,255,255,0.06);
    }
    .footer__bottom p {
      max-width: 30ch;
      line-height: 1.5;
      font-size: 0.68rem;
    }
    .footer__legal {
      justify-content: center;
      gap: 0.4rem;
      font-size: 0.68rem;
    }
    .footer__legal span { font-size: 0.6rem; }

    /* Watermark oculto en mobile */
    .footer__watermark { display: none; }
  }
</style>
